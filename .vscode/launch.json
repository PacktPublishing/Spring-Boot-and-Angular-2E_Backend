    "version": "0.2.0",
    "configurations": [
        {
            "type": "java",
            "name": "Current File",
            "request": "launch",
            "mainClass": "${file}"
        },
        {
            "type": "java",
            "name": "InventoryMsApplication",
            "request": "launch",
            "mainClass": "com.packt.bookstore.inventory.InventoryMsApplication",
            "projectName": "com.packt.bookstore-inventory-ms",
            "vmArgs": " -Dcom.sun.management.jmxremote -Dcom.sun.management.jmxremote.port=53528 -Dcom.sun.management.jmxremote.authenticate=false -Dcom.sun.management.jmxremote.ssl=false -Dspring.jmx.enabled=true -Djava.rmi.server.hostname=localhost -Dspring.application.admin.enabled=true -Dspring.boot.project.name=com.packt.bookstore-inventory-ms"
        },
        {
            "type": "java",
            "name": "UserMsApplication",
            "request": "launch",
            "mainClass": "com.packt.bookstore.users.UserMsApplication",
            "projectName": "com.packt.bookstore-user-ms",
            "vmArgs": " -Dcom.sun.management.jmxremote -Dcom.sun.management.jmxremote.port=53534 -Dcom.sun.management.jmxremote.authenticate=false -Dcom.sun.management.jmxremote.ssl=false -Dspring.jmx.enabled=true -Djava.rmi.server.hostname=localhost -Dspring.application.admin.enabled=true -Dspring.boot.project.name=com.packt.bookstore-user-ms"
        },
        {
            "type": "java",
            "name": "Spring Boot-EurekaServerApplication<com.packt.bookstore-eureka-server>",
            "request": "launch",
            "cwd": "${workspaceFolder}",
            "mainClass": "com.packt.bookstore.eureka_server.EurekaServerApplication",
            "projectName": "com.packt.bookstore-eureka-server",
            "args": "",
            "envFile": "${workspaceFolder}/.env"
        },
        {
            "type": "java",
            "name": "Spring Boot-GatewayServerApplication<com.packt.bookstore-gateway-server>",
            "request": "launch",
            "cwd": "${workspaceFolder}",
            "mainClass": "com.packt.bookstore.gateway_server.GatewayServerApplication",
            "projectName": "com.packt.bookstore-gateway-server",
            "args": "",
            "envFile": "${workspaceFolder}/.env"
        }
    ]
}